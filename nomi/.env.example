# Firebase Configuration
# Kopiere diese Datei nach .env und füge deine Firebase Credentials ein

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# API base URL for AI proxy (optional in dev, defaults to /api)
VITE_API_BASE_URL=/api

# AI Provider Configuration
VITE_AI_PROVIDER=claude
VITE_AI_MODEL=claude-3-5-sonnet-20241022

# Client-side logging/monitoring (optional)
VITE_LOG_ENDPOINT=
VITE_MONITORING_ENABLED=false

# AI Server Configuration
AI_SERVER_PORT=5174
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
